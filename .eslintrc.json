{
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "extends": "eslint:recommended",
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "no-console": "off",
    "semi": ["error", "always"],
    "eqeqeq": ["error", "always"]
  },
  "overrides": [
    {
      "files": ["web/**/*.{js,jsx}"],
      "env": { "browser": true, "node": false },
      "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module",
        "ecmaFeatures": { "jsx": true }
      },
      "plugins": ["react"],
      "extends": ["plugin:react/recommended"],
      "settings": { "react": { "version": "detect" } },
      "rules": {
        "react/react-in-jsx-scope": "off",
        "react/prop-types": "off"
      }
    }
  ]
}
